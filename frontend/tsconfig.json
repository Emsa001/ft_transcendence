{
    "compilerOptions": {
        "target": "es5",
        "lib": ["dom", "es2019"],
        "jsx": "react",
        "allowSyntheticDefaultImports": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "typeRoots": ["./react/types", "./node_modules/@types"],
        "types": ["node", "webpack-env"],
        "baseUrl": "./",
        "paths": {
            "@shared/*": ["src/shared/*"],
            "@components/*": ["src/shared/components/*"],
            "@features/*": ["src/features/*"],
            "shared/*": ["../shared/*"]
        }
    },
    "include": ["src/**/*", "react/**/*", "react/types/global.d.ts"],
    "exclude": ["node_modules", "dist"]
}
