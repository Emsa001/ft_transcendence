{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "license": "ISC",
    "author": "",
    "type": "module",
    "main": "src/bin/server.ts",
    "scripts": {
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "npx tsx -r tsconfig-paths/register src/bin/server.ts",
        "dev": "tsx watch src/bin/server.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@faker-js/faker": "^9.9.0",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.0.1",
        "@fastify/middie": "^9.0.3",
        "@fastify/multipart": "^9.0.3",
        "@fastify/static": "^8.2.0",
        "@fastify/websocket": "^11.2.0",
        "bcrypt": "^6.0.0",
        "dotenv": "^16.5.0",
        "fastify": "^5.4.0",
        "fastify-decorators": "^3.16.1",
        "fastify-metrics": "^12.1.0",
        "google-auth-library": "^9.15.1",
        "jsonwebtoken": "^9.0.2",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.2.2",
        "sequelize": "^6.37.7",
        "sequelize-typescript": "^2.1.6",
        "shared": "file:../shared",
        "sharp": "^0.34.3",
        "speakeasy": "^2.0.0",
        "sqlite3": "^5.1.7",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.15.33",
        "@types/qrcode": "^1.5.5",
        "@types/speakeasy": "^2.0.10",
        "@types/validator": "^13.15.2",
        "jest": "^30.0.5",
        "prettier": "^3.6.2",
        "ts-jest": "^29.4.1"
    },
    "jest": {
        "preset": "ts-jest",
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/$1",
            "^shared$": "<rootDir>/../../shared/src/index.ts"
        },
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    },
    "@types/ws": "^8.18.1"
}
